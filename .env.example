# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: gemini | openai | claude
LLM_PROVIDER=gemini

# ── Gemini (default — free tier available) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Models: gemini-2.0-flash (fast/free), gemini-1.5-pro (higher quality)
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Anthropic / Claude (optional) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Evaluation LLM ────────────────────────────────────────────────────────────
# Used by RAGAS + DeepEval — keep cheap (mini/flash) to control eval costs
EVAL_LLM_PROVIDER=gemini
EVAL_GEMINI_MODEL=gemini-2.0-flash

# ── LangSmith Tracing (optional but recommended) ──────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=financial-research-agent

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required by EDGAR — format: "Your Name your@email.com"
SEC_EDGAR_USER_AGENT=Your Name your@email.com

# ── Agent Settings ────────────────────────────────────────────────────────────
RETRIEVAL_CONFIDENCE_THRESHOLD=0.7
MAX_RETRIEVAL_ITERATIONS=3
TOP_K_CHUNKS=10
RERANKER_TOP_K=5
